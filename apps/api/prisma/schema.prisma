// Prisma schema for MAHA Peptides OS
// Only high-level structure, no business logic
// No medically suggestive fields or names

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ✅ STRICT product categories - ONLY these allowed (per GUARDRAILS.md)
enum ProductCategory {
  RESEARCH_PEPTIDES
  ANALYTICAL_REFERENCE_MATERIALS
  LABORATORY_ADJUNCTS
  RESEARCH_COMBINATIONS
  MATERIALS_SUPPLIES
  MERCHANDISE
}

// User role types
enum UserRole {
  CLIENT // Individual researchers
  CLINIC // Medical facilities (B2B)
  DISTRIBUTOR // Wholesale distributors (B2B)
  ADMIN // Platform administrators
}

// Payment link status
enum PaymentLinkStatus {
  PENDING
  SENT
  CLICKED
  PAID
  EXPIRED
  CANCELED
}

// Forbidden term severity levels
enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ✅ Compliance-safe file types only (per GUARDRAILS.md)
enum BatchFileType {
  COA // Certificate of Analysis (REQUIRED)
  MSDS // Material Safety Data Sheet
  PRODUCT_IMAGE // Product photos
  TECHNICAL_SHEET // Chemical technical specifications
}

// Product strength units for variants
enum StrengthUnit {
  MG
  IU
  ML
}

enum ProductVisibility {
  B2C_ONLY
  B2B_ONLY
  BOTH
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
  BACKORDER
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  BUSINESS_LICENSE
  TAX_ID
  FACILITY_LICENSE
  OFFICER_ID
  ADDRESS_PROOF
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CatalogType {
  B2C_ONLY
  B2B_ONLY
}

enum ProcessingType {
  STANDARD       // 2 business days (FREE)
  EXPEDITED      // 1 business day ($25 fee)
  RUSH           // Same day if before 10am MST ($50 fee)
}

model User {
  id                        String                     @id @default(uuid())
  email                     String                     @unique
  password                  String
  firstName                 String?
  lastName                  String?
  role                      UserRole                   @default(CLIENT)
  phone                     String?
  isActive                  Boolean                    @default(true)
  uploads                   BatchFile[]
  orders                    Order[]
  complianceAcknowledgments ComplianceAcknowledgment[]
  kycVerification           KycVerification?
  stockNotifications        StockNotification[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model KycVerification {
  id              String      @id @default(uuid())
  userId          String      @unique
  status          KycStatus   @default(NOT_SUBMITTED)
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  lastRejectionAt DateTime?
  canResubmitAt   DateTime?
  internalNotes   String?
  user            User        @relation(fields: [userId], references: [id])
  documents       KycDocument[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([canResubmitAt])
}

model KycDocument {
  id             String               @id @default(uuid())
  verificationId String
  documentType   DocumentType
  fileId         String
  status         DocumentReviewStatus @default(PENDING)
  uploadedAt     DateTime             @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?
  rejectionReason String?
  verification   KycVerification      @relation(fields: [verificationId], references: [id])
  file           File                 @relation(fields: [fileId], references: [id])

  @@index([verificationId, documentType])
  @@index([status])
}

model Org {
  id        String   @id @default(uuid())
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Distributor {
  id           String      @id @default(uuid())
  name         String
  contactEmail String?
  contactPhone String?
  website      String?
  clinics      Clinic[]
  priceLists   PriceList[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orders       Order[]
}

model Clinic {
  id            String       @id @default(uuid())
  name          String
  contactEmail  String?
  contactPhone  String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  priceLists    PriceList[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  orders        Order[]
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String?          @unique
  description      String?
  sku              String           @unique
  imageUrl         String?          // Product image URL (local path or external URL)
  category         ProductCategory? // ✅ Now uses enum instead of String
  form             String?
  concentration    String?
  casNumber        String? // Chemical Abstracts Service number
  molecularFormula String? // e.g., "C19H34N6O5"
  visibility       ProductVisibility   @default(B2C_ONLY)
  isDraft          Boolean             @default(true)
  currentStock     Int                 @default(0)
  lowStockThreshold Int?               @default(25)
  stockStatus      StockStatus         @default(OUT_OF_STOCK)
  expectedRestockDate DateTime?
  displayOrder     Int?
  isFeatured       Boolean             @default(false)
  isActive         Boolean          @default(true)
  variants         ProductVariant[]
  batches          ProductBatch[]
  priceTiers       PriceTier[]
  stockNotifications StockNotification[]
  priceListItems   PriceListItem[]
  orderItems       OrderItem[]
  inventory        Inventory[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}


model ProductVariant {
  id            String        @id @default(uuid())
  productId     String
  product       Product       @relation(fields: [productId], references: [id])
  strengthValue Decimal       @db.Decimal(10, 2)
  strengthUnit  StrengthUnit
  sku           String        @unique
  priceCents    Int?
  isActive      Boolean       @default(true)
  batches       ProductBatch[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([productId])
  @@index([strengthUnit])
}

model ProductBatch {
  id                  String      @id @default(uuid())
  productId           String
  product             Product     @relation(fields: [productId], references: [id])
  variantId           String?
  variant             ProductVariant? @relation(fields: [variantId], references: [id])
  batchCode           String      @unique
  purityPercent       Decimal     @db.Decimal(5, 2)
  manufacturedAt      DateTime
  expiresAt           DateTime
  storageInstructions String?
  qtyInitial          Decimal     @db.Decimal(12, 2)
  qtyAvailable        Decimal     @db.Decimal(12, 2)
  testingLab          String? // Lab that performed COA testing
  coaFileId           String? // Reference to COA file (required before activation)
  coaFile             File?       @relation("BatchCoaFile", fields: [coaFileId], references: [id])
  testDate            DateTime?
  methodology         String?
  concentration       Decimal?    @db.Decimal(10, 2)
  molecularWeight     Decimal?    @db.Decimal(10, 2)
  appearance          String?
  solubility          String?
  isActive            Boolean     @default(false) // ✅ Requires COA before activation
  isAvailable         Boolean     @default(true)
  files               BatchFile[]
  priceTiers          PriceTier[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([variantId])
  @@index([variantId, isActive])
}

model BatchFile {
  id           String        @id @default(uuid())
  batchId      String
  batch        ProductBatch  @relation(fields: [batchId], references: [id])
  type         BatchFileType
  filePath     String
  uploadedById String?
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model File {
  id              String    @id @default(uuid())
  filename        String
  originalName    String
  mimetype        String
  size            Int
  storageProvider String    @default("r2")
  storageBucket   String
  storageKey      String
  storageUrl      String?
  uploadedBy      String?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  productBatches  ProductBatch[] @relation("BatchCoaFile")
  kycDocuments    KycDocument[]

  @@index([storageKey])
  @@index([uploadedBy])
  @@index([storageBucket])
}

model PriceList {
  id            String          @id @default(uuid())
  name          String
  description   String?
  currency      String          @default("USD")
  effectiveFrom DateTime        @default(now())
  expiresAt     DateTime?
  distributorId String
  clinicId      String?
  distributor   Distributor     @relation(fields: [distributorId], references: [id])
  clinic        Clinic?         @relation(fields: [clinicId], references: [id])
  items         PriceListItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PriceListItem {
  id           String    @id @default(uuid())
  priceListId  String
  productId    String
  label        String?
  unitQuantity String?
  price        Decimal   @db.Decimal(12, 2)
  currency     String?
  isActive     Boolean   @default(true)
  priceList    PriceList @relation(fields: [priceListId], references: [id])
  product      Product   @relation(fields: [productId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PriceTier {
  id          String      @id @default(uuid())
  productId   String?
  batchId     String?
  catalogType CatalogType
  minQuantity Int         @default(1)
  maxQuantity Int?
  price       Decimal     @db.Decimal(12, 2)
  label       String?
  isActive    Boolean     @default(true)
  product     Product?    @relation(fields: [productId], references: [id])
  batch       ProductBatch? @relation(fields: [batchId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([productId, catalogType, minQuantity])
  @@index([batchId, catalogType, minQuantity])
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLING
  SHIPPED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  DISPUTED
}

enum OrderAccountType {
  RETAIL
  CLINIC
  DISTRIBUTOR
}

model Address {
  id             String   @id @default(uuid())
  line1          String
  line2          String?
  city           String
  state          String
  postalCode     String
  country        String
  ordersShipping Order[]  @relation("OrderShippingAddress")
  ordersBilling  Order[]  @relation("OrderBillingAddress")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Order {
  id                       String                    @id @default(uuid())
  orderNumber              String?                   @unique // Human-readable order number (e.g., "MP-2024-00001")
  userId                   String
  user                     User                      @relation(fields: [userId], references: [id])
  clinicId                 String?
  clinic                   Clinic?                   @relation(fields: [clinicId], references: [id])
  distributorId            String?
  distributor              Distributor?              @relation(fields: [distributorId], references: [id])
  accountType              OrderAccountType
  status                   OrderStatus

  // Customer contact info (for invoice emails and shipping)
  firstName                String?
  lastName                 String?
  phone                    String?
  email                    String? // Email for payment invoice (may differ from user.email)

  subtotal                 Decimal                   @db.Decimal(12, 2)
  tax                      Decimal                   @db.Decimal(12, 2)
  shipping                 Decimal                   @db.Decimal(12, 2)
  total                    Decimal                   @db.Decimal(12, 2)

  // Order insurance and processing options
  insuranceSelected        Boolean                   @default(false)
  insuranceFee             Decimal                   @default(0) @db.Decimal(10, 2)
  processingType           ProcessingType            @default(STANDARD)
  processingFee            Decimal                   @default(0) @db.Decimal(10, 2)
  expectedShipDate         DateTime?

  shippingAddressId        String?
  shippingAddress          Address?                  @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId         String?
  billingAddress           Address?                  @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  items                    OrderItem[]
  payments                 Payment[]
  shipments                Shipment[] // Shippo shipments
  paymentLink              PaymentLink? // ✅ Private payment link
  complianceAcknowledgment ComplianceAcknowledgment? // ✅ Required checkout compliance
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  paidAt                   DateTime?
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Decimal  @db.Decimal(12, 2)
  unitPrice Decimal  @db.Decimal(12, 2)
  lineTotal Decimal  @db.Decimal(12, 2)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id                   String        @id @default(uuid())
  orderId              String
  order                Order         @relation(fields: [orderId], references: [id])
  amount               Decimal       @db.Decimal(12, 2)
  currency             String        @default("USD")
  status               PaymentStatus
  method               String? // "ZELLE", "CASHAPP", "WIRE_TRANSFER"
  paymentProof         String? // URL to uploaded screenshot/receipt
  transactionReference String? // Zelle confirmation / CashApp transaction ID
  verifiedById         String? // Admin who verified payment
  verifiedAt           DateTime?
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Inventory {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  updatedAt DateTime @updatedAt
}

model StockNotification {
  id         String   @id @default(uuid())
  productId  String
  email      String
  userId     String?
  notified   Boolean  @default(false)
  notifiedAt DateTime?
  product    Product  @relation(fields: [productId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([productId, notified])
  @@index([email])
  @@unique([productId, email, notified])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  adminId   String?
  orgId     String?
  entityType String?
  entityId  String?
  changesBefore Json?
  changesAfter  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([adminId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

// ✅ COMPLIANCE MODELS - Required for GUARDRAILS.md enforcement

model ForbiddenTerm {
  id          String            @id @default(uuid())
  term        String            @unique
  severity    ViolationSeverity @default(HIGH)
  category    String? // e.g., "medical", "dosing", "therapeutic"
  replacement String? // Suggested compliant alternative
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ComplianceAcknowledgment {
  id                     String   @id @default(uuid())
  orderId                String   @unique
  order                  Order    @relation(fields: [orderId], references: [id])
  userId                 String
  user                   User     @relation(fields: [userId], references: [id])
  researchPurposeOnly    Boolean // ☐ I acknowledge that all products are for research purposes only
  responsibilityAccepted Boolean // ☐ I accept full responsibility for handling and disposal
  noMedicalAdvice        Boolean // ☐ I understand no information constitutes medical advice
  ageConfirmation        Boolean // ☐ I confirm I am at least 21 years of age
  termsAccepted          Boolean // ☐ I have read and agree to Terms of Service
  ipAddress              String
  userAgent              String?
  createdAt              DateTime @default(now())

  @@index([userId])
  @@index([orderId])
}

model PaymentLink {
  id            String            @id @default(uuid())
  orderId       String            @unique
  order         Order             @relation(fields: [orderId], references: [id])
  token         String            @unique
  amount        Decimal           @db.Decimal(12, 2)
  currency      String            @default("USD")
  status        PaymentLinkStatus @default(PENDING)
  expiresAt     DateTime
  sentVia       String[] // ["SMS", "EMAIL"]
  customerPhone String?
  customerEmail String
  processorType String? // "EPICOR_PROPELLO", "WIRE_TRANSFER", "CRYPTO"
  processorUrl  String? // External payment processor URL
  clickedAt     DateTime?
  paidAt        DateTime?
  clickCount    Int               @default(0)
  ipAddresses   String[] // Track IPs that clicked the link
  smsLogs       SmsLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([token])
  @@index([orderId])
  @@index([status])
}

model SmsLog {
  id            String       @id @default(uuid())
  paymentLinkId String?
  paymentLink   PaymentLink? @relation(fields: [paymentLinkId], references: [id])
  toPhone       String
  message       String
  status        String // "QUEUED", "SENT", "DELIVERED", "FAILED"
  twilioSid     String?
  errorMessage  String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime     @default(now())

  @@index([paymentLinkId])
  @@index([toPhone])
  @@index([status])
}

// ✅ SHIPPO INTEGRATION - Shipping management
model Shipment {
  id                String    @id @default(uuid())
  orderId           String
  order             Order     @relation(fields: [orderId], references: [id])
  carrier           String // "USPS", "FedEx", "UPS"
  service           String // "Priority", "Express", "Ground"
  trackingNumber    String    @unique
  labelUrl          String? // Shippo label PDF URL
  shippoId          String? // Shippo shipment ID
  shippedAt         DateTime  @default(now())
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
}

// ✅ SETTINGS - Store payment instructions and site config

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., "PAYMENT_ZELLE_EMAIL", "PAYMENT_CASHAPP_TAG"
  value     String   @db.Text
  category  String?  // "PAYMENT", "SHIPPING", "GENERAL"
  isPublic  Boolean  @default(false) // If true, can be accessed by frontend
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([category])
}

// ✅ CONTENT MANAGEMENT - Blog & FAQ

model Faq {
  id          String   @id @default(uuid())
  question    String
  answer      String   @db.Text
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
}

model Blog {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String    @db.Text
  excerpt        String?   @db.Text
  featuredImage  String?
  seoTitle       String?
  seoDescription String?   @db.Text
  keywords       String?   @db.Text
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@index([slug])
}
