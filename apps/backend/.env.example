# Environment variables for MAHA Peptides OS Backend
#
# NEVER commit secrets to version control

# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/maha_peptides

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=3600s

# Mail
MAIL_FROM=no-reply@maha-peps.com
MAILGUN_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Payment
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Compliance
KYC_PROVIDER_API_KEY=
