# Web App Environment Variables
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_WEB_BASE_URL=https://app.example.com
NEXT_PUBLIC_ADMIN_TOKEN=your-admin-jwt-token

# Mailgun / SMTP (for client-side integration or API calls)
NEXT_PUBLIC_MAILGUN_DOMAIN=your-mailgun-domain
NEXT_PUBLIC_SMTP_FROM_EMAIL=notifications@example.com

# Payment Information (Manual Collection via Zelle/CashApp)
NEXT_PUBLIC_ZELLE_ID=payments@mahapeptides.com
NEXT_PUBLIC_CASHAPP_TAG=$MahaPeptides

# Server-side Rendering/Build (if needed)
SERVER_API_BASE_URL=https://api.example.com
