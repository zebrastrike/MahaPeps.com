# Shared service defaults for local development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=maha_dev
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

REDIS_URL=redis://redis:6379
REDIS_PORT=6379

API_PORT=3001
WEB_PORT=3000
NGINX_PORT=8080

MAILHOG_SMTP_PORT=1025
MAILHOG_HTTP_PORT=8025
MAILHOG_HOST=mailhog

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Payment Processor - Epicor Propello (or similar high-risk processor)
EPICOR_PROPELLO_ENABLED=false  # Set to true when approved
EPICOR_PROPELLO_API_URL=https://api.epicorpropello.com/v1
EPICOR_PROPELLO_API_KEY=your_api_key_here
EPICOR_PROPELLO_MERCHANT_ID=your_merchant_id
EPICOR_PROPELLO_WEBHOOK_SECRET=your_webhook_secret

# Wire Transfer Details (Backup Payment Method)
WIRE_TRANSFER_ENABLED=true
WIRE_BANK_NAME="JP Morgan Chase"
WIRE_ACCOUNT_NAME="MAHA Peptides LLC"
WIRE_ACCOUNT_NUMBER=****1234
WIRE_ROUTING_NUMBER=021000021
WIRE_SWIFT_CODE=CHASUS33

# SMS Service (Twilio) - For payment link delivery
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Email Service (Mailgun)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=mg.mahapeps.com
MAILGUN_FROM_EMAIL=noreply@mahapeps.com
MAILGUN_FROM_NAME="MAHA Peptides"

# Payment Link Settings
PAYMENT_LINK_EXPIRY_HOURS=48
PAYMENT_LINK_TOKEN_LENGTH=32

# Compliance & Security
ENCRYPTION_KEY=32-byte-hex-key-for-pii-encryption
ADMIN_ALLOWED_IPS=127.0.0.1,192.168.1.1  # Comma-separated IPs for admin access

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Database Connection (for apps/api)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public
